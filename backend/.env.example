APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false
APP_LOG_LEVEL=info
LOG_FORMAT=json
USER_HASH_SECRET=<generate-a-random-string-and-never-rotate>
APP_SECRET_KEY=<generate-a-secure-random-key>
ACCESS_TOKEN_EXPIRY_HOURS=1
REFRESH_TOKEN_EXPIRY_HOURS=720

SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=<your-supabase-service-role-key>
SUPABASE_JWT_SECRET=<your-supabase-jwt-secret>
DATABASE_URL=postgresql://<user>:<password>@<host>:<port>/<database>

FILEBASE_ENDPOINT=https://s3.filebase.io
FILEBASE_ACCESS_KEY_ID=<your-filebase-key>
FILEBASE_SECRET_ACCESS_KEY=<your-filebase-secret>
FILEBASE_REGION=auto
FILEBASE_BUCKET=obsidian

TEMPORAL_HOST=temporal:7233
TEMPORAL_NAMESPACE=obsidian
TEMPORAL_TASK_QUEUE_WORKFLOW=obsidian-workflow
TEMPORAL_TASK_QUEUE_GPU=obsidian-gpu
TEMPORAL_TASK_QUEUE_CPU=obsidian-cpu
TEMPORAL_TASK_QUEUE_DB=obsidian-db
TEMPORAL_TLS_CERT_PATH=
TEMPORAL_TLS_KEY_PATH=
TEMPORAL_RETENTION=168h
TEMPORAL_POSTGRES_USER=temporal
TEMPORAL_POSTGRES_PASSWORD=<generate-a-strong-password>
TEMPORAL_UI_CORS_ORIGINS=http://localhost:8233
TEMPORAL_AUTH_ENABLED=false

REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_TLS_ENABLED=false
REDIS_MAX_CONNECTIONS=10

OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-<region>.grafana.net/otlp
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic%20<base64-token>
OTEL_TRACE_SAMPLE_RATIO=1.0
OTEL_SERVICE_NAME=
# Default base for the api service. The workflow worker service overrides this
# at the compose level (see docker-compose.*.yml) so each reports its own
# service.name in Grafana.
OTEL_SERVICE_NAME_BASE=obsidian-api
OTEL_SERVICE_NAMESPACE=obsidian
OTEL_SERVICE_INSTANCE_ID=

BODY_LOG_MAX_BYTES=4096

FIREBASE_CREDENTIALS_JSON=
FIREBASE_WEB_API_KEY=

AVATAR_UPLOAD_URL_TTL_MINUTES=15
AVATAR_MAX_SIZE_MB=5
AVATAR_ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/webp

DOCS_USERNAME=admin
DOCS_PASSWORD=<set-a-docs-password>
