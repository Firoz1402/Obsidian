# ── Temporal local runtime data (compose volumes / bind mounts) ──────────────
temporal/data/
temporal/postgres/
temporal/certs/*
!temporal/certs/.gitkeep

# ── Credentials mounted into containers ──────────────────────────────────────
firebase-service-account*.json
