{
  "annotations": {"list": [{"builtIn": 1, "datasource": {"type": "grafana", "uid": "-- Grafana --"}, "enable": true, "hide": true, "iconColor": "rgba(0, 211, 255, 1)", "name": "Annotations & Alerts", "type": "dashboard"}]},
  "description": "Obsidian — logs in tabular format. Pulls from Loki, parses the JSON body, and renders one row per log line with sortable/filterable columns. Service variable lists every service.name observed in Loki — both dev (e.g. obsidian-app-management-development) and prod (obsidian-app-management-production) appear separately.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "liveNow": false,
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["obsidian", "logs", "table"],
  "templating": {
    "list": [
      {"current": {"selected": false, "text": "Loki", "value": "Loki"}, "hide": 0, "includeAll": false, "label": "Loki", "multi": false, "name": "DS_LOKI", "options": [], "query": "loki", "refresh": 1, "type": "datasource"},
      {"allValue": ".+", "current": {"selected": true, "text": "All", "value": "$__all"}, "datasource": {"type": "loki", "uid": "${DS_LOKI}"}, "definition": "label_values(service_name)", "hide": 0, "includeAll": true, "label": "Service", "multi": true, "name": "service", "options": [], "query": "label_values(service_name)", "refresh": 2, "sort": 1, "type": "query"},
      {"allValue": ".*", "current": {"selected": true, "text": "All", "value": "$__all"}, "datasource": {"type": "loki", "uid": "${DS_LOKI}"}, "definition": "label_values({service_name=~\"$service\"}, deployment_environment)", "hide": 0, "includeAll": true, "label": "Environment", "multi": true, "name": "env", "options": [], "query": "label_values({service_name=~\"$service\"}, deployment_environment)", "refresh": 2, "sort": 1, "type": "query"},
      {"current": {"selected": true, "text": ["info", "warning", "error", "critical"], "value": ["info", "warning", "error", "critical"]}, "hide": 0, "includeAll": true, "label": "Level", "multi": true, "name": "level", "options": [{"selected": true, "text": "All", "value": "$__all"}, {"selected": false, "text": "info", "value": "info"}, {"selected": false, "text": "warning", "value": "warning"}, {"selected": false, "text": "error", "value": "error"}, {"selected": false, "text": "critical", "value": "critical"}], "query": "info,warning,error,critical", "type": "custom"},
      {"current": {"selected": false, "text": "", "value": ""}, "hide": 0, "label": "Trace ID", "name": "trace_id", "options": [{"selected": true, "text": "", "value": ""}], "query": "", "type": "textbox"},
      {"current": {"selected": false, "text": "", "value": ""}, "hide": 0, "label": "Hashed User UUID", "name": "hashed_user_uuid", "options": [{"selected": true, "text": "", "value": ""}], "query": "", "type": "textbox"},
      {"current": {"selected": false, "text": "", "value": ""}, "hide": 0, "label": "Route contains", "name": "route_q", "options": [{"selected": true, "text": "", "value": ""}], "query": "", "type": "textbox"},
      {"current": {"selected": false, "text": "", "value": ""}, "hide": 0, "label": "Search (line)", "name": "search", "options": [{"selected": true, "text": "", "value": ""}], "query": "", "type": "textbox"}
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Obsidian — Logs (Table View)",
  "uid": "obsidian-logs-table",
  "version": 1,
  "weekStart": "",
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Lines (range)",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
      "targets": [{"expr": "sum(count_over_time({service_name=~\"$service\"} | json | (deployment_environment=~\"$env\" or deployment_environment=\"\") [$__range]))", "refId": "A", "instant": true, "queryType": "instant"}],
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "center", "textMode": "value", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "color": {"mode": "continuous-BlPu"}}}
    },
    {
      "id": 2, "type": "stat", "title": "Errors (range)",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
      "targets": [{"expr": "sum(count_over_time({service_name=~\"$service\"} | json | level=~\"(?i)error|critical\" | (deployment_environment=~\"$env\" or deployment_environment=\"\") [$__range]))", "refId": "A", "instant": true, "queryType": "instant"}],
      "options": {"colorMode": "background", "graphMode": "area", "justifyMode": "center", "textMode": "value", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "green"}, {"color": "yellow", "value": 1}, {"color": "orange", "value": 10}, {"color": "red", "value": 100}]}}}
    },
    {
      "id": 3, "type": "stat", "title": "Warnings (range)",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
      "targets": [{"expr": "sum(count_over_time({service_name=~\"$service\"} | json | level=~\"(?i)warning\" | (deployment_environment=~\"$env\" or deployment_environment=\"\") [$__range]))", "refId": "A", "instant": true, "queryType": "instant"}],
      "options": {"colorMode": "background", "graphMode": "area", "justifyMode": "center", "textMode": "value", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "green"}, {"color": "yellow", "value": 10}, {"color": "orange", "value": 100}]}}}
    },
    {
      "id": 4, "type": "stat", "title": "Unique Users (range)",
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
      "targets": [{"expr": "count(count by (hashed_user_uuid) (count_over_time({service_name=~\"$service\"} | json | hashed_user_uuid != \"\" [$__range])))", "refId": "A", "instant": true, "queryType": "instant"}],
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "center", "textMode": "value", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "color": {"mode": "continuous-GrYlRd"}}}
    },
    {
      "id": 5, "type": "stat", "title": "Unique Traces (range)",
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
      "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
      "targets": [{"expr": "count(count by (trace_id) (count_over_time({service_name=~\"$service\"} | json | trace_id != \"\" [$__range])))", "refId": "A", "instant": true, "queryType": "instant"}],
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "center", "textMode": "value", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "color": {"mode": "continuous-BlYlRd"}}}
    },
    {
      "id": 6, "type": "stat", "title": "Services Reporting",
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0},
      "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
      "targets": [{"expr": "count(count by (service_name) (count_over_time({service_name=~\"$service\"} | json [$__range])))", "refId": "A", "instant": true, "queryType": "instant"}],
      "options": {"colorMode": "value", "graphMode": "none", "justifyMode": "center", "textMode": "value", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "color": {"mode": "continuous-BlPu"}}}
    },

    {
      "id": 10, "type": "timeseries", "title": "Log Volume by Level (lines/s)",
      "description": "Click-and-drag to zoom into a spike, then scroll the table below.",
      "gridPos": {"h": 7, "w": 24, "x": 0, "y": 4},
      "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
      "targets": [
        {"expr": "sum(rate({service_name=~\"$service\"} | json | level=~\"(?i)info\" | (deployment_environment=~\"$env\" or deployment_environment=\"\") [$__interval]))", "refId": "A", "legendFormat": "info"},
        {"expr": "sum(rate({service_name=~\"$service\"} | json | level=~\"(?i)warning\" | (deployment_environment=~\"$env\" or deployment_environment=\"\") [$__interval]))", "refId": "B", "legendFormat": "warning"},
        {"expr": "sum(rate({service_name=~\"$service\"} | json | level=~\"(?i)error\" | (deployment_environment=~\"$env\" or deployment_environment=\"\") [$__interval]))", "refId": "C", "legendFormat": "error"},
        {"expr": "sum(rate({service_name=~\"$service\"} | json | level=~\"(?i)critical\" | (deployment_environment=~\"$env\" or deployment_environment=\"\") [$__interval]))", "refId": "D", "legendFormat": "critical"}
      ],
      "fieldConfig": {"defaults": {"unit": "logs", "custom": {"drawStyle": "bars", "lineWidth": 1, "fillOpacity": 80, "gradientMode": "opacity", "stacking": {"mode": "normal"}}}, "overrides": [
        {"matcher": {"id": "byName", "options": "info"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "#7EB26D"}}]},
        {"matcher": {"id": "byName", "options": "warning"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "#EAB839"}}]},
        {"matcher": {"id": "byName", "options": "error"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "#FA6400"}}]},
        {"matcher": {"id": "byName", "options": "critical"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "#E02F44"}}]}
      ]},
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "sum"]}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },

    {
      "id": 20, "type": "table", "title": "Logs",
      "description": "One row per log line. Sortable + filterable per column. Use the variables at the top to narrow by service / env / level / trace / user / route / free-text.",
      "gridPos": {"h": 24, "w": 24, "x": 0, "y": 11},
      "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
      "targets": [{
        "expr": "{service_name=~\"$service\"} | json | (deployment_environment=~\"$env\" or deployment_environment=\"\") | level=~\"(?i)$level\" | (trace_id=~\".*$trace_id.*\" or trace_id=\"\") | (hashed_user_uuid=~\".*$hashed_user_uuid.*\" or hashed_user_uuid=\"\") | (route=~\".*$route_q.*\" or route=\"\") |~ \"(?i)$search\"",
        "refId": "A",
        "queryType": "range",
        "maxLines": 1000
      }],
      "transformations": [
        {"id": "extractFields", "options": {"source": "labels", "format": "auto", "keepTime": false, "replace": false}},
        {"id": "organize", "options": {
          "excludeByName": {
            "labels": true,
            "id": true,
            "tsNs": true,
            "Line": false,
            "filename": true,
            "service_version": true,
            "service_instance_id": true,
            "service_namespace": true,
            "exported_level": true,
            "detected_level": true
          },
          "renameByName": {
            "Time": "Time",
            "service_name": "Service",
            "deployment_environment": "Env",
            "level": "Level",
            "event": "Event",
            "method": "Method",
            "route": "Route",
            "status_code": "Status",
            "duration_ms": "Duration (ms)",
            "cpu_ms": "CPU (ms)",
            "response_size_bytes": "Resp Bytes",
            "request_id": "Request ID",
            "trace_id": "Trace ID",
            "span_id": "Span ID",
            "hashed_user_uuid": "User",
            "login_email": "Login Email",
            "client_ip": "Client IP",
            "exception_type": "Exception",
            "exception_message": "Exc Message",
            "error_message": "Error",
            "Line": "Raw"
          },
          "indexByName": {
            "Time": 0,
            "level": 1,
            "service_name": 2,
            "deployment_environment": 3,
            "event": 4,
            "method": 5,
            "route": 6,
            "status_code": 7,
            "duration_ms": 8,
            "cpu_ms": 9,
            "response_size_bytes": 10,
            "hashed_user_uuid": 11,
            "trace_id": 12,
            "span_id": 13,
            "request_id": 14,
            "login_email": 15,
            "client_ip": 16,
            "exception_type": 17,
            "exception_message": 18,
            "error_message": 19,
            "Line": 20
          }
        }}
      ],
      "fieldConfig": {
        "defaults": {"custom": {"align": "left", "displayMode": "auto", "filterable": true, "inspect": true, "minWidth": 60}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "Time"}, "properties": [{"id": "custom.width", "value": 180}, {"id": "unit", "value": "dateTimeAsIso"}]},
          {"matcher": {"id": "byName", "options": "Level"}, "properties": [{"id": "custom.width", "value": 70}, {"id": "mappings", "value": [
            {"options": {"info": {"color": "green", "text": "info"}, "INFO": {"color": "green", "text": "info"}, "warning": {"color": "yellow", "text": "warn"}, "WARNING": {"color": "yellow", "text": "warn"}, "error": {"color": "orange", "text": "error"}, "ERROR": {"color": "orange", "text": "error"}, "critical": {"color": "red", "text": "crit"}, "CRITICAL": {"color": "red", "text": "crit"}}, "type": "value"}
          ]}, {"id": "custom.displayMode", "value": "color-text"}]},
          {"matcher": {"id": "byName", "options": "Service"}, "properties": [{"id": "custom.width", "value": 200}]},
          {"matcher": {"id": "byName", "options": "Env"}, "properties": [{"id": "custom.width", "value": 90}]},
          {"matcher": {"id": "byName", "options": "Event"}, "properties": [{"id": "custom.width", "value": 200}]},
          {"matcher": {"id": "byName", "options": "Method"}, "properties": [{"id": "custom.width", "value": 70}]},
          {"matcher": {"id": "byName", "options": "Route"}, "properties": [{"id": "custom.width", "value": 220}]},
          {"matcher": {"id": "byName", "options": "Status"}, "properties": [{"id": "custom.width", "value": 70}, {"id": "custom.displayMode", "value": "color-background"}, {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "green"}, {"color": "blue", "value": 300}, {"color": "yellow", "value": 400}, {"color": "red", "value": 500}]}}]},
          {"matcher": {"id": "byName", "options": "Duration (ms)"}, "properties": [{"id": "unit", "value": "ms"}, {"id": "decimals", "value": 1}, {"id": "custom.width", "value": 110}, {"id": "custom.displayMode", "value": "gradient-gauge"}, {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "green"}, {"color": "yellow", "value": 250}, {"color": "orange", "value": 750}, {"color": "red", "value": 2000}]}}]},
          {"matcher": {"id": "byName", "options": "CPU (ms)"}, "properties": [{"id": "unit", "value": "ms"}, {"id": "decimals", "value": 1}, {"id": "custom.width", "value": 90}]},
          {"matcher": {"id": "byName", "options": "Resp Bytes"}, "properties": [{"id": "unit", "value": "bytes"}, {"id": "custom.width", "value": 100}]},
          {"matcher": {"id": "byName", "options": "User"}, "properties": [{"id": "custom.width", "value": 140}]},
          {"matcher": {"id": "byName", "options": "Trace ID"}, "properties": [{"id": "custom.width", "value": 280}, {"id": "links", "value": [{"title": "Open trace in Tempo", "url": "/explore?left=%7B%22datasource%22:%22Tempo%22,%22queries%22:%5B%7B%22query%22:%22${__value.raw}%22,%22queryType%22:%22traceId%22%7D%5D%7D", "targetBlank": true}]}]},
          {"matcher": {"id": "byName", "options": "Span ID"}, "properties": [{"id": "custom.width", "value": 160}]},
          {"matcher": {"id": "byName", "options": "Request ID"}, "properties": [{"id": "custom.width", "value": 280}]},
          {"matcher": {"id": "byName", "options": "Exception"}, "properties": [{"id": "custom.width", "value": 180}]},
          {"matcher": {"id": "byName", "options": "Exc Message"}, "properties": [{"id": "custom.width", "value": 320}]},
          {"matcher": {"id": "byName", "options": "Error"}, "properties": [{"id": "custom.width", "value": 320}]},
          {"matcher": {"id": "byName", "options": "Login Email"}, "properties": [{"id": "custom.width", "value": 220}]},
          {"matcher": {"id": "byName", "options": "Client IP"}, "properties": [{"id": "custom.width", "value": 130}]},
          {"matcher": {"id": "byName", "options": "Raw"}, "properties": [{"id": "custom.hidden", "value": true}]}
        ]
      },
      "options": {
        "showHeader": true,
        "footer": {"show": true, "reducer": ["count"], "fields": ["Time"]},
        "cellHeight": "sm",
        "sortBy": [{"desc": true, "displayName": "Time"}]
      }
    },

    {
      "id": 30, "type": "table", "title": "🔴 Errors Only — Compact Table",
      "gridPos": {"h": 14, "w": 24, "x": 0, "y": 35},
      "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
      "targets": [{
        "expr": "{service_name=~\"$service\"} | json | level=~\"(?i)warning|error|critical\" | (deployment_environment=~\"$env\" or deployment_environment=\"\") | (trace_id=~\".*$trace_id.*\" or trace_id=\"\") | (hashed_user_uuid=~\".*$hashed_user_uuid.*\" or hashed_user_uuid=\"\") | (route=~\".*$route_q.*\" or route=\"\")",
        "refId": "A",
        "queryType": "range",
        "maxLines": 500
      }],
      "transformations": [
        {"id": "extractFields", "options": {"source": "labels", "format": "auto", "keepTime": false, "replace": false}},
        {"id": "organize", "options": {
          "excludeByName": {"labels": true, "id": true, "tsNs": true, "Line": true, "filename": true, "service_version": true, "service_instance_id": true, "service_namespace": true, "request_id": true, "span_id": true, "client_ip": true, "response_size_bytes": true, "cpu_ms": true, "exported_level": true, "detected_level": true},
          "renameByName": {"service_name": "Service", "deployment_environment": "Env", "level": "Level", "event": "Event", "method": "Method", "route": "Route", "status_code": "Status", "duration_ms": "Duration", "hashed_user_uuid": "User", "trace_id": "Trace", "exception_type": "Exception", "exception_message": "Exc Msg", "error_message": "Error"},
          "indexByName": {"Time": 0, "level": 1, "service_name": 2, "event": 3, "method": 4, "route": 5, "status_code": 6, "duration_ms": 7, "exception_type": 8, "exception_message": 9, "error_message": 10, "hashed_user_uuid": 11, "trace_id": 12}
        }}
      ],
      "fieldConfig": {
        "defaults": {"custom": {"align": "left", "displayMode": "auto", "filterable": true, "inspect": true}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "Time"}, "properties": [{"id": "custom.width", "value": 180}, {"id": "unit", "value": "dateTimeAsIso"}]},
          {"matcher": {"id": "byName", "options": "Level"}, "properties": [{"id": "custom.width", "value": 70}, {"id": "custom.displayMode", "value": "color-background"}, {"id": "mappings", "value": [{"options": {"warning": {"color": "yellow"}, "error": {"color": "orange"}, "critical": {"color": "red"}}, "type": "value"}]}]},
          {"matcher": {"id": "byName", "options": "Status"}, "properties": [{"id": "custom.width", "value": 70}, {"id": "custom.displayMode", "value": "color-background"}, {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "green"}, {"color": "yellow", "value": 400}, {"color": "red", "value": 500}]}}]},
          {"matcher": {"id": "byName", "options": "Duration"}, "properties": [{"id": "unit", "value": "ms"}, {"id": "custom.width", "value": 90}]},
          {"matcher": {"id": "byName", "options": "Trace"}, "properties": [{"id": "custom.width", "value": 280}, {"id": "links", "value": [{"title": "Open trace", "url": "/explore?left=%7B%22datasource%22:%22Tempo%22,%22queries%22:%5B%7B%22query%22:%22${__value.raw}%22,%22queryType%22:%22traceId%22%7D%5D%7D", "targetBlank": true}]}]}
        ]
      },
      "options": {"showHeader": true, "cellHeight": "sm", "sortBy": [{"desc": true, "displayName": "Time"}]}
    }
  ],
  "links": []
}
